// aidir main configuration
// JSON5 format: supports comments, unquoted keys, trailing commas
// Secrets and paths come from .env via ${VAR} or ${VAR:-default} substitution
{
  "version": "1.0",
  "title": "aidir 1",
  "instance": "${AIDIR_INSTANCE:-aidir1}",
  "root": "${AIDIR_ROOT}",
  "redis": {
    "host": "${REDIS_HOST:-127.0.0.1}",
    "port": ${REDIS_PORT:-6379},
    "password": "${REDIS_PASSWORD:-}"
  },
  "logging": {
    // Default level for all subsystems. String or int (0-7, systemd-journald scale).
    "level": "${LOG_LEVEL:-error}",
    // Timezone for log timestamps.
    // Use "local" for server local timezone, "UTC", or IANA name (e.g. "Europe/Moscow").
    "timezone": "${LOG_TIMEZONE:-local}",
    // Seconds between log wipe runs. 0 = never wipe.
    "wipe_period": ${LOG_WIPE_PERIOD:-10000},
    "wipe_max_age": ${LOG_WIPE_MAX_AGE:-1000000}, 
    max_log_size: ${MAX_LOG_SIZE:-1000000}, // max size in bytes for individual log files; 0 = unlimited
    "levels": { // thresholds for individual per-type log files
      "workers": "warning",
      "http": "warning",
      "webui": "warning",
    },
    "alllevels": { // thresholds for all.log
      "core": 3, // WARNING
      "workers": 3,
      "http": 3, // INFO
      "webui": 3
    }
  },
  // Resources to track (VRAM etc).
  // alive_time: seconds model stays in VRAM after last task (Ollama default is 300s).
  //   Memory is considered occupied during this window; scheduler will force-unload if needed.
  // keep_alive: keep model loaded for this many seconds after last use via cron pings (0=disabled).
  // keep_alive_period: cron ping interval for keep_alive (should be < Ollama's auto-unload time).
  // provider: id from models.providers, used to resolve API URL for force-unload/keep-alive calls.
  "resources":[
        {
            "id":"local_machine",
            "type":"cuda",
            "arch": "nvidia",
            "limits":{
                "VRAM":10000, //Максимум можно использовать 10гб
            },
            "alive_time": 300,       // Ollama keeps models in VRAM ~5min after last call
            "keep_alive": 5000,      // Keep model loaded for 5000s after last call (0=disabled)
            "keep_alive_period": 250, // Ping every 250s so model stays before Ollama's 300s unload
            "provider": "ollama_local" // Provider id for force-unload / keep-alive API calls
        },
        {
            "id":"remote_machine",
            "type":"cuda",
            "limits":{
                "VRAM":20000,
            },
            "alive_time": 300,
            "keep_alive": 0,          // No active keep-alive for remote machine
            "keep_alive_period": 0,
            "provider": "ollama_remote"
        },
    ],

  "endpoints": [
    {
      "id": "openaix",
      "api": "openaix",
      "port": ${OPENAIX_ENDPOINT_PORT:-21434},
      "bindAddress": "${OPENAIX_ENDPOINT_HOST:-0.0.0.0}",
      "logging": {
        // Per-endpoint log levels (overrides logging.levels.http / logging.alllevels.http)
        "level": "info",
        "alllevel": "warning"
      },
      // worker used for agent tasks; falls back to workers.default if omitted
      "worker": "openaix",
      // worker used for pre-agent context building
      "context_builder_worker": "context_builder",
      // Timeout for entire request (queue + execution)
      "request_timeout": ${REQUEST_TIMEOUT:-100},
      "middlewares": [] // TODO: add middleware ids here when needed
    },
    {
      "id": "mcp",
      "api": "mcp",
      "port": ${MCP_ENDPOINT_PORT:-20001},
      "bindAddress": "${MCP_ENDPOINT_HOST:-0.0.0.0}",
      "logging": {
        // Example: keep endpoint logs more verbose for MCP debugging
        "level": "debug",
        "alllevel": "info"
      },
      // Timeout for entire request (queue + execution)
      "request_timeout": ${REQUEST_TIMEOUT:-100},
      "tools": {
        "search": {
          "worker": "web_search",
          /*!! REMOVED 
          "description": "Test web search tool",
          "inputSchema": {
            "type": "object",
            "properties": {
              "query": {"type": "string"},
              "limit": {"type": "integer"}
            }
          }
          */
        },
        "fetch": {
          "worker": "web_fetch",
          /*!! REMOVED
          "description": "Test web fetch tool",
          "inputSchema": {
            "type": "object",
            "properties": {
              "url": {"type": "string"},
              "maxChars": {"type": "integer"}
            },
            "required": ["url"]
          }
          */
        },
        "selftest": {
          "worker": "selftest",
          /*!! REMOVED
          "description": "System health self-test tool",
          "inputSchema": {
            "type": "object",
            "properties": {}
          }
          */
        }
      }
    }
  ],
  "workers": {
    // Max turns for internal tool loop in agent workers that support tools.
    // Can be overridden per worker via workers.items.<worker_id>.tools_max_turns.
    "tools_max_turns": 50,
    "items": {
      "call_ollama": {
        // Upstream ollama provider id from models.providers
        "provider": "ollama_local",
        "logging": {
          "level": "debug",
          "alllevel": "warning"
        }
      },
      "openaix": {
        "enabled": true,
        "provider": "ollama_local",
        // Optional override for this worker only (falls back to workers.tools_max_turns)
        // "tools_max_turns": 50,
        // Timeout for single HTTP request to upstream LLM
        "request_timeout": ${REQUEST_TIMEOUT:-100},
        "logging": {
          "level": "debug",
          "alllevel": "warning",
          "save_llm_request": true,
        },
        tools:{
          "search":{
              worker:"web_search",//используется worker web_search
          },
          "fetch":{
              worker:"web_fetch",
          },
          "selftest":{
              worker:"selftest",
          },
        }
      },
      "reject_agent": {
        "enabled": true,
        "fallbacks": ["echo_agent"],
        "retry_count": 2,
        "retry_period": 1,
        "on_reject": {
          "unavailable": {
            "action": "fallback-retry"
          },
          "busy": {
            "action": "retry",
            "retry_count": 1,
            "retry_period": 0
          },
          "error": {
            "action": "cancel"
          }
        }
      },
      "echo_agent": {
        "enabled": true
      },
      "web_search": {
        "enabled": true,
        "provider": "brave",
        "apiKey": "${BRAVE_APIKEY}",
        // Timeout for Brave API request
        "request_timeout": ${REQUEST_TIMEOUT:-100}
      },
      "web_fetch": {
        "enabled": true,
        "provider": "brave",
        "apiKey": "${BRAVE_APIKEY}",
        // Timeout for Brave LLM Context API request
        "request_timeout": ${REQUEST_TIMEOUT:-100}
      },
      "selftest": {
        "enabled": true,
        "includeWorkers": true,
        "includeResources": true
      },
      "context_builder": {
        "enabled": true
      },
      "context_add_internal_tools": {
        "enabled": true,
        "tools": {}  // Dict of internal tools: {tool_name: {description, ...}}
      },
      "context_render_openclaw_style": {
        "enabled": true
      },
      "external_mcp": {
        "enabled": true,
        "tools_ttl": 300,
        // Optional default auth for all remote MCP servers of this worker.
        // Per-server servers.<id>.auth overrides this object.
        "auth": {
          "type": "bearer",
          "token": "${WORKSPACE_TOKEN:-changeme}"
        },
        "logging": {
          "level": "debug",
          "alllevel": "info",
        },
        "servers": {
          "sndbx": {
              "type": "http",
              "url": "http://127.0.0.1:30081/mcp",
          },
          "filesystem": {
            "type": "http",
            "url": "http://127.0.0.1:20001/mcp"
          },
        },
      },    
    },
    "default": "call_ollama"
  },
  "middleware": {
    "items": {} // TODO: add middleware configs here
  },
  "models": {
    "providers": {
      "ollama_local": {
        "baseUrl": "${OLLAMA_BASE_URL:-http://127.0.0.1:11434}",
        "api": "ollama",
        "models": [ // populated at runtime via /api/tags
          {
              id:"qwen3.5:9b",
              "name": "smart model",
              "contextWindow": 80000,
              resources:{
                  "local_machine":{
                      VRAM:9800, 
                  }
              },
          },
          {
              id:"qwen3.5:4b",
              "name": "fast model",
              "reasoning": false,
              "input": [
                  "text",
                  "image"
              ],
              resources:{
                  "local_machine":{
                      VRAM:6800, 
                  }
              },
          },
          {
              id:"bjoernb/gemma4-e2b-fast:latest",
              "name": "very fast model",
              "reasoning": false,
              "input": [
                  "text",
                  "image"
              ],
              resources:{
                  "local_machine":{
                      VRAM:8000, 
                  }
              },
          },
          
        ] 
      },
      "ollama_remote": {
        "baseUrl": "${OLLAMA_REMOTE_BASE_URL:-http://127.0.0.1:11434}",
        "api": "ollama",
        "models": [// populated at runtime via /api/tags
          {
              id:"qwen3.5:9b",
              "name": "smart model",
              "contextWindow": 80000,
              resources:{
                  "local_machine":{
                      VRAM:9800, 
                  }
              },
          },
          {
              id:"qwen3.5:4b",
              "name": "fast model",
              "reasoning": false,
              "input": [
                  "text",
                  "image"
              ],
              resources:{
                  "local_machine":{
                      VRAM:6800, 
                  }
              },
          },
          {
              id:"bjoernb/gemma4-e2b-fast:latest",
              "name": "very fast model",
              "reasoning": false,
              "input": [
                  "text",
                  "image"
              ],
              resources:{
                  "local_machine":{
                      VRAM:8000, 
                  }
              },
          },
        ] 
      },

    }
  },
  "webui": {
    "port": ${WEBUI_PORT:-20082},
    "bind": "${WEBUI_HOST:-127.0.0.1}",
    "auth": {
      "mode": "login",
      "session_ttl": 86400, // seconds
      "users": [
        {
          "login": "${ROOT_USER:-admin}",
          "password": "${ROOT_PASSWORD:-changeme}",
          "permissions": [
            "all"
          ]
        }
      ]
    },
    // Timeout for HTTP requests to backend endpoints from WebUI
    "request_timeouts": {
      "ollama_chat":     ${WEBUI_TIMEOUT_OLLAMA_CHAT:-120},   // ollama /api/chat test
      "mcp_proxy":       ${WEBUI_TIMEOUT_MCP_PROXY:-60},      // MCP endpoint proxy
      "model_list":      ${WEBUI_TIMEOUT_MODEL_LIST:-20},     // list models from endpoint
      "agent_test":      ${WEBUI_TIMEOUT_AGENT_TEST:-45}      // test agent request
    }
  },
  "users": {
    // API users for OpenAI/Ollama-compatible endpoints (not WebUI users).
    "items": [
      {
        "login": "api-test-user",
        "token": "${API_USER_TOKEN:-test-token-123456789}",
        "envids": ["test-12345", "test-23456"],
        "autoassign_envid": "test-12345"
      }
    ]
  },
  "tasks": {
    "restart_wait_timeout": ${TASK_RESTART_WAIT_TIMEOUT_SECONDS:-120},
    "queue_timeout": ${TASK_QUEUE_TIMEOUT_SECONDS:-300},
    "run_timeout": ${TASK_RUN_TIMEOUT_SECONDS:-300},
    "external_task_live": ${EXTERNAL_TASK_LIVE_SECONDS:-2500000}
  },
  "envids": {
    "check_period_minutes": ${ENVIDS_CHECK_PERIOD_MINUTES:-600},
    "store_duration_minutes": ${ENVIDS_STORE_DURATION_MINUTES:-60000},
    "default_context_building": {
      "bootstrapMaxChars": ${BOOTSTRAP_MAX_CHARS:-32000},
      "bootstrapTotalMaxChars": ${BOOTSTRAP_TOTAL_MAX_CHARS:-150000}
    },
    // Preset envids. Config values override Redis-stored values on startup.
    "items": {
//-------------------
      "test-12345":{
        description:"Demo env id",
        context:{ 
            items:{
                workspace:{
                    type:"mcp", //доступ через mcp file access
                    endid:"default-env-token", //envid for MCP
                    host:"127.0.0.1:30081",
                    location:"/root/workspace/",
                    token:"${WORKSPACE_TOKEN:-changeme}", 
                },
            }
        },
      },
      "test-23456":{
        parent:"test-12345", 
        description:"Demo envid which uses another envid as a template",
        context:{
            files:[//redefile files array
                    {
                        "name":"AGENTS.md",
                        "location": "./AGENTS1.md",//redefine  one field
                        "token":"${WORKSPACE_TOKEN:-changeme}",
                    }   
                ],
        }
      },
//-------------------      
    }
  },

}
