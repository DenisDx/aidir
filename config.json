// aidir main configuration
// JSON5 format: supports comments, unquoted keys, trailing commas
// Secrets and paths come from .env via ${VAR} or ${VAR:-default} substitution
{
  "version": "1.0",
  "title": "aidir 1",
  "instance": "${AIDIR_INSTANCE:-aidir1}",
  "root": "${AIDIR_ROOT}",
  "redis": {
    "host": "${REDIS_HOST:-127.0.0.1}",
    "port": ${REDIS_PORT:-6379},
    "password": "${REDIS_PASSWORD:-}"
  },
  "logging": {
    // Default level for all subsystems. String or int (0-7, systemd-journald scale).
    "level": "${LOG_LEVEL:-info}",
    // Seconds between log wipe runs. 0 = never wipe.
    "wipe_period": ${LOG_WIPE_PERIOD:-0},
    // wipe_max_age: 86400,  // seconds; defaults to wipe_period if not set
    "levels": { // thresholds for individual per-type log files
      "workers": "debug",
      "http": "info",
      "webui": "info"
    },
    "alllevels": { // thresholds for all.log
      "core": 4, // WARNING
      "workers": 4,
      "http": 6, // INFO
      "webui": 4
    }
  },
  // Resources to track (VRAM etc). Empty in MVP1 - resource checks are TODO.
  "resources":[
        {
            "id":"local_machine",
            "type":"cuda",
            "arch": "nvidia",
            "limits":{
                "VRAM":10000, //Максимум можно использовать 10гб
            }
        },
        {
            "id":"remote_machine",
            "type":"cuda",
            "limits":{
                "VRAM":20000,
            }
        },
    ],

  "endpoints": [
    {
      "id": "openaix",
      "api": "openaix",
      "port": ${OPENAIX_ENDPOINT_PORT:-21434},
      "bindAddress": "${OPENAIX_ENDPOINT_HOST:-0.0.0.0}",
      // worker used for agent tasks; falls back to workers.default if omitted
      "worker": "openaix",
      "middlewares": [] // TODO: add middleware ids here when needed
    },
    {
      "id": "mcp",
      "api": "mcp",
      "port": ${MCP_ENDPOINT_PORT:-20001},
      "bindAddress": "${MCP_ENDPOINT_HOST:-0.0.0.0}",
      "tools": {
        "search": {
          "worker": "web_search",
          "description": "Test web search tool",
          "inputSchema": {
            "type": "object",
            "properties": {
              "query": {"type": "string"},
              "limit": {"type": "integer"}
            }
          }
        },
        "fetch": {
          "worker": "web_fetch",
          "description": "Test web fetch tool",
          "inputSchema": {
            "type": "object",
            "properties": {
              "url": {"type": "string"},
              "maxChars": {"type": "integer"}
            },
            "required": ["url"]
          }
        },
        "selftest": {
          "worker": "selftest",
          "description": "System health self-test tool",
          "inputSchema": {
            "type": "object",
            "properties": {}
          }
        }
      }
    }
  ],
  "workers": {
    "items": {
      "call_ollama": {
        // Upstream ollama provider id from models.providers
        "provider": "ollama_local",
        "logging": {
          "level": "debug",
          "alllevel": "info"
        }
      },
      "openaix": {
        "enabled": true,
        "provider": "ollama_local",
        "timeoutSeconds": 300,
        "logging": {
          "level": "debug",
          "alllevel": "info"
        },
        tools:{
          "search":{
              worker:"web_search",//используется worker web_search
          },
          "fetch":{
              worker:"web_fetch",
          },
          "selftest":{
              worker:"selftest",
          },
        }
      },
      "reject_agent": {
        "enabled": true,
        "fallbacks": ["echo_agent"],
        "retry_count": 2,
        "retry_period": 1,
        "on_reject": {
          "unavailable": {
            "action": "fallback-retry"
          },
          "busy": {
            "action": "retry",
            "retry_count": 1,
            "retry_period": 0
          },
          "error": {
            "action": "cancel"
          }
        }
      },
      "echo_agent": {
        "enabled": true
      },
      "web_search": {
        "enabled": true,
        "provider": "mock"
      },
      "web_fetch": {
        "enabled": true,
        "timeoutSeconds": 30
      },
      "selftest": {
        "enabled": true,
        "includeWorkers": true,
        "includeResources": true
      }
    },
    "default": "call_ollama"
  },
  "middleware": {
    "items": {} // TODO: add middleware configs here
  },
  "models": {
    "providers": {
      "ollama_local": {
        "baseUrl": "${OLLAMA_BASE_URL:-http://127.0.0.1:11434}",
        "api": "ollama",
        "models": [] // populated at runtime via /api/tags
      }
    }
  },
  "webui": {
    "port": ${WEBUI_PORT:-20080},
    "bind": "${WEBUI_HOST:-127.0.0.1}",
    "auth": {
      "mode": "login",
      "session_ttl": 86400, // seconds
      "users": [
        {
          "login": "${ROOT_USER:-admin}",
          "password": "${ROOT_PASSWORD:-changeme}",
          "permissions": [
            "all"
          ]
        }
      ]
    }
  },
  "tasks": {
    "queue_timeout": ${TASK_QUEUE_TIMEOUT_SECONDS:-300},
    "run_timeout": ${TASK_RUN_TIMEOUT_SECONDS:-300}
  }
}
