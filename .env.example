# ─── Instance ───────────────────────────────────────────────
# Unique name for this aidir instance (used as Redis key prefix)
AIDIR_INSTANCE=aidir1
# Absolute path to project root
AIDIR_ROOT=/home/user/aidir

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── OpenAIx endpoint (the port aidir exposes to clients) ────
OPENAIX_ENDPOINT_PORT=21434
OPENAIX_ENDPOINT_HOST=0.0.0.0

# ─── MCP endpoint (JSON-RPC over HTTP) ──────────────────────
MCP_ENDPOINT_PORT=20001
MCP_ENDPOINT_HOST=0.0.0.0

# ─── Upstream Ollama (where real inference happens) ─────────
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ─── WebUI ──────────────────────────────────────────────────
WEBUI_PORT=20082
WEBUI_HOST=0.0.0.0
# Public HTTP port for nginx. Must not be equal to WEBUI_PORT.
NGINX_HTTP_PORT=8080

# ─── Auth ───────────────────────────────────────────────────
ROOT_USER=admin
ROOT_PASSWORD=changeme

# ─── Logging ────────────────────────────────────────────────
LOG_WIPE_PERIOD=10000
LOG_WIPE_MAX_AGE=1000000

# ─── Cron ───────────────────────────────────────────────────
CRON_PERIOD=1

# ─── Task timeouts (seconds) ────────────────────────────────
# Graceful restart drain timeout for already running tasks.
TASK_RESTART_WAIT_TIMEOUT_SECONDS=120
# Max waiting time before the task reaches running for the first time.
TASK_QUEUE_TIMEOUT_SECONDS=300
# Max total execution time after the task has started running.
TASK_RUN_TIMEOUT_SECONDS=300
EXTERNAL_TASK_LIVE_SECONDS=2500000
# Max duration of one outbound HTTP request to an upstream LLM/API.
REQUEST_TIMEOUT=100

# ─── WebUI request timeouts (seconds) ────────────────────────
# Timeouts for WebUI backend HTTP requests to test endpoints
WEBUI_TIMEOUT_OLLAMA_CHAT=120
WEBUI_TIMEOUT_MCP_PROXY=60
WEBUI_TIMEOUT_MODEL_LIST=20
WEBUI_TIMEOUT_AGENT_TEST=45

# ─── TLS (optional, handled by nginx) ───────────────────────
# TLS_CERT_PATH=/etc/ssl/certs/server.crt
# TLS_KEY_PATH=/etc/ssl/private/server.key
# TLS_PORT=443
# TLS_PORT_EXTERNAL=443

# ─── External AI providers (optional) ───────────────────────
# DASHSCOPE_API_KEY=
# BRAVE_APIKEY=
